{
  "manifest_version": 3,
  "name": "Click & Copy",
  "version": "1.0",
  "description": "Restores right-click, text selection, and copy/paste on all websites.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Click & Copy – active"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
